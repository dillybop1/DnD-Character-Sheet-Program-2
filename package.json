{
  "name": "dnd-character-sheet",
  "private": true,
  "version": "0.1.0",
  "description": "Offline-first Electron desktop app for building and exporting dynamic D&D character sheets.",
  "author": "Dylan Umphress",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "engines": {
    "node": ">=22 <24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsup && electron-builder",
    "build:win-local": "tsc -b && vite build && tsup && electron-builder --win nsis --x64 -c.win.signAndEditExecutable=false",
    "pack:win-local": "tsc -b && vite build && tsup && electron-builder --win dir --x64 -c.win.signAndEditExecutable=false",
    "pack": "tsc -b && vite build && tsup && electron-builder --dir",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.1.0",
    "@fontsource/source-sans-3": "^5.1.0",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.44.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  },
  "build": {
    "appId": "com.dylanumphress.dndcharactersheet",
    "productName": "DND Character Sheet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "icon": "icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "icon.png"
    },
    "extraMetadata": {
      "main": "dist-electron/main.cjs"
    }
  }
}
